# CineTime Backend Environment Variables Configuration
# ==================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files with real credentials to version control

# ==================================================
# SERVER CONFIGURATION
# ==================================================
# Application server port (default: 8090)
SERVER_PORT=8090

# ==================================================
# DATABASE CONFIGURATION
# ==================================================
# PostgreSQL database connection URL
# Format: jdbc:postgresql://<host>:<port>/<database_name>
# Example for local: jdbc:postgresql://localhost:5432/cinetime_db
# Example for K8s: jdbc:postgresql://shared-postgres-service:5432/cinetime_db
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/cinetime_db

# Database username
SPRING_DATASOURCE_USERNAME=db_admin

# Database password
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# ==================================================
# JWT SECURITY CONFIGURATION
# ==================================================
# JWT secret key for token signing and verification
# MUST be a strong random string (minimum 32 characters recommended)
# Generate with: openssl rand -base64 32
CINETIME_APP_JWTSECRET=your_jwt_secret_key_here_minimum_32_characters

# ==================================================
# GOOGLE OAUTH CONFIGURATION
# ==================================================
# Google OAuth 2.0 Client ID for social login
# Obtain from: https://console.cloud.google.com/apis/credentials
APP_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# ==================================================
# EMAIL CONFIGURATION (SendGrid)
# ==================================================
# SendGrid API Key for sending emails (password reset, notifications, etc.)
# Obtain from: https://app.sendgrid.com/settings/api_keys
# Required format: SG.xxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# ==================================================
# NOTES FOR DEPLOYMENT
# ==================================================
# Local Development:
#   - Use localhost for database host
#   - Copy this file to .env and source it before running the application
#   - Example: source .env && mvn spring-boot:run
#
# Kubernetes Deployment:
#   Environment variables are sourced from multiple K8s resources:
#
#   From backend-secret (cinetime/k8s/secrets/backend-secret.yaml):
#     - SPRING_DATASOURCE_URL (database-url)
#     - CINETIME_APP_JWTSECRET (jwt-secret)
#     - APP_GOOGLE_CLIENT_ID (google-client-id)
#     - SENDGRID_API_KEY (sendgrid-api-key)
#
#   From postgres-secret (shared-database/k8s/secrets/postgres-secret.yaml):
#     - SPRING_DATASOURCE_USERNAME (username)
#     - SPRING_DATASOURCE_PASSWORD (password)
#     NOTE: Shared across all applications using the centralized database
#
#   From backend-config (cinetime/k8s/configmaps/backend-configmap.yaml):
#     - SERVER_PORT
#     - SPRING_JPA_HIBERNATE_DDL_AUTO
#     - SPRING_JPA_SHOW_SQL
#     - SPRING_DATASOURCE_DRIVER_CLASS_NAME
#
#   Database URL format for K8s:
#     jdbc:postgresql://postgres.database.svc.cluster.local:5432/cinetime_db
#
# Security Best Practices:
#   - Never commit real credentials to version control
#   - Use strong, randomly generated passwords and secrets
#   - Rotate secrets periodically
#   - Use different credentials for different environments (dev, staging, prod)
#   - In production, consider using secret management tools (HashiCorp Vault, AWS Secrets Manager, etc.)
#   - Database credentials are shared in K8s - coordinate changes with other applications
